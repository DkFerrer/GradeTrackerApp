<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GradeTrackerApp.Views.AddSubjectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Subject"
    BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Add New Subject"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   Margin="0,10,0,0" />

            <Label Text="Fill in your subject details below"
                   FontSize="13"
                   TextColor="Gray" />

            <Label Text="SUBJECT CODE"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="Gray" />
            <Entry x:Name="CodeEntry"
                   Placeholder="e.g. 3098"
                   BackgroundColor="White" />

            <Label Text="SUBJECT NAME"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="Gray" />
            <Entry x:Name="NameEntry"
                   Placeholder="e.g. Application Development"
                   BackgroundColor="White" />

            <Label Text="PROFESSOR"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="Gray" />
            <Entry x:Name="ProfessorEntry"
                   Placeholder="e.g. Prof. Cruz"
                   BackgroundColor="White" />

            <Label Text="UNITS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="Gray" />
            <Entry x:Name="UnitsEntry"
                   Placeholder="e.g. 3"
                   Keyboard="Numeric"
                   BackgroundColor="White" />

            <Label Text="SEMESTER"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="Gray" />
            <Entry x:Name="SemesterEntry"
                   Placeholder="e.g. 1st Sem 2025-26"
                   BackgroundColor="White" />

            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="Red"
                   FontSize="13"
                   IsVisible="False"
                   HorizontalOptions="Center" />

            <Button Text="Add Subject"
                    BackgroundColor="#1A8C7A"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    Clicked="OnSaveClicked" />

            <Button Text="Cancel"
                    BackgroundColor="Transparent"
                    TextColor="#1A8C7A"
                    BorderColor="#1A8C7A"
                    BorderWidth="1"
                    CornerRadius="12"
                    HeightRequest="52"
                    Clicked="OnCancelClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>